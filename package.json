{
  "name": "@xgheaven/eslint-config-xgheaven",
  "version": "0.5.0",
  "description": "Flat ESLint 9 config factory for xgheaven, based on neostandard with TypeScript and React options",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "lint": "pnpm run build && eslint .",
    "test": "pnpm run build && pnpm run test:exports && pnpm run test:base && pnpm run test:typescript && pnpm run test:react",
    "test:exports": "node scripts/test-exports.js",
    "test:base": "eslint -c playground/base/eslint.config.js playground/base",
    "test:typescript": "eslint -c playground/typescript/eslint.config.js playground/typescript",
    "test:react": "eslint -c playground/react/eslint.config.js playground/react",
    "build": "tsc -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:XGHeaven/eslint-config-xgheaven.git"
  },
  "author": "XGHeaven",
  "license": "MIT",
  "engines": {
    "node": ">=20.19"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "prettier": ">=3.0.0",
    "typescript": ">=5.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-n": "^17.21.3",
    "eslint-plugin-prettier": "^5.5.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "neostandard": "^0.13.0",
    "typescript-eslint": "^8.33.1"
  },
  "devDependencies": {
    "@types/react": "^19.1.6",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "typescript": "^5.8.3",
    "@types/node": "^22.0.0"
  }
}
